.env.*.local

# Logs
*.log

# Temporary files
tmp/
temp/

# Build folders (if you use custom ones)
dist/
build/

# Coverage reports
coverage.out

# Generated files (if any)
*.gen.go

# Docker
*.tar

# Air (live reload tool)
.air.toml

# SQLite (if you ever use it locally)
*.db
*.sqlite3

*.txt